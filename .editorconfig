# EditorConfig helps maintain consistent coding styles across editors/IDEs
# https://editorconfig.org

root = true

# Defaults for all files
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# Makefiles use tabs
[Makefile]
indent_style = tab
indent_size = 4

# YAML (Kubernetes/Flux/Helm values)
[*.{yml,yaml}]
indent_style = space
indent_size = 2

# Markdown: keep trailing spaces (for line breaks)
[*.md]
trim_trailing_whitespace = false

# JSON
[*.json]
indent_size = 2

# Shell scripts
[*.{sh,bash,zsh}]
end_of_line = lf
indent_style = space
indent_size = 2

# Ignore vendored or generated files (if present)
[{**/charts/**,**/dist/**,**/build/**,**/.git/**}]
trim_trailing_whitespace = false
insert_final_newline = false
